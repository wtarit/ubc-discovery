# Database
DATABASE_URL=postgresql+asyncpg://ubcadmin:NewcomersDB2026!@<RDS_ENDPOINT>:5432/ubcnewcomers

# AWS (S3, Bedrock, SNS)
AWS_REGION=us-west-2
S3_BUCKET_NAME=
S3_ENDPOINT_URL=https://s3.us-west-2.amazonaws.com
SNS_PLATFORM_APP_ARN=

# Firebase Auth
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Email (Mailgun SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=noreply@yourdomain.com

# Admin API key (for bot/script access to admin endpoints like event creation)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# Frontend URL (for OpenGraph redirect + og:url tag; set to CloudFront domain in production)
FRONTEND_URL=http://localhost:8081

# CORS — add your production web URL here (e.g. https://app.yourdomain.com)
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

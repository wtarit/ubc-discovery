# Database
DATABASE_URL=postgresql+asyncpg://ubcadmin:NewcomersDB2026!@<RDS_ENDPOINT>:5432/ubcnewcomers

# AWS
AWS_REGION=us-west-2
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_CLIENT_SECRET=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=https://s3.us-west-2.amazonaws.com
SNS_PLATFORM_APP_ARN=

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Override email domain enforcement
TEST_ALLOWED_EMAILS=["example@gmail.com"]

# CORS — add your production web URL here (e.g. https://app.yourdomain.com)
CORS_ALLOWED_ORIGINS=["http://localhost:8081"]

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@RDS_ENDPOINT:5432/DATABASE

# AWS (S3, Bedrock)
AWS_REGION=us-west-2
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=https://YOUR_BUCKET_NAME.s3.us-west-2.amazonaws.com

# Firebase Auth
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Sender Email
EMAIL_SENDER_EMAIL=noreply@ubcdiscovery.com

# Admin API key (for bot/script access to admin endpoints like event creation)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# CORS — add your production web URL here (e.g. https://app.yourdomain.com)
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
